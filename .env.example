# ==========================================================================
#  content-console — ตัวอย่างไฟล์ env
#  วิธีใช้: คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริงในแต่ละบรรทัด
#  หมายเหตุ: ถ้าปล่อยค่าเป็น placeholder (ค่าเริ่มต้นด้านล่าง) ระบบจะทำงานใน
#            "MOCK MODE" อัตโนมัติ — เก็บข้อมูลในหน่วยความจำ ไม่ยิง API จริง
#            เหมาะสำหรับทดสอบ UI/ฟลว์ในเฟส 1 โดยยังไม่ต้องมีความลับ
# ==========================================================================

# --- โหมดทำงาน -------------------------------------------------------------
# auto = ตรวจเองว่ามี key ครบไหม (แนะนำ) | mock = บังคับ mock | live = บังคับใช้ของจริง
APP_MODE=auto
# 🔒 สวิตช์นิรภัย: true = อนุญาตปล่อยจริง (โพสต์เว็บ+FB) | false/ไม่ตั้ง = ปิด (publishDue ไม่ทำอะไร)
PUBLISH_ENABLED=false

# --- แบรนด์ / ธีมเนื้อหา ----------------------------------------------------
# ชื่อเว็บที่แสดงบนหัวเว็บ (placeholder — เจ้าของเคาะชื่อ/โดเมนจริงทีหลัง)
NEXT_PUBLIC_SITE_NAME=SiamAthlete Blog
# ธีม/แนวเนื้อหาที่ AI ต้องเขียน (แบรนด์ SiamAthlete)
CONTENT_THEME=ฟิตเนส เพาะกาย วิทยาศาสตร์การออกกำลังกาย และโภชนาการสำหรับนักกีฬา (แบรนด์ SiamAthlete)
# ลิงก์โซเชียลที่แสดงในหน้าติดต่อ
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/SiamAthlete
NEXT_PUBLIC_LINE_URL=https://line.me

# --- Supabase (ฐานข้อมูล + เก็บรูป) ----------------------------------------
# ที่มา: https://supabase.com → สร้างโปรเจกต์ → Project Settings → API
#   NEXT_PUBLIC_SUPABASE_URL      = "Project URL"
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = "anon public" key (ใช้ฝั่ง client อ่านบทความ published)
#   SUPABASE_SERVICE_ROLE_KEY     = "service_role" key (ฝั่ง server เท่านั้น ห้ามเปิดเผย!)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# ชื่อ storage bucket สำหรับเก็บรูป (สร้างด้วย supabase/storage.sql)
SUPABASE_BUCKET=article-images
# prefix ชื่อตาราง — ตั้งเป็น "sa_" เมื่อแชร์ฐานข้อมูลกับโปรเจกต์อื่น (กันตารางชนกัน)
# ถ้าใช้โปรเจกต์ Supabase แยกเฉพาะ ปล่อยว่างได้
SUPABASE_TABLE_PREFIX=sa_

# --- ผู้เขียนบทความ -------------------------------------------------------
# ทางเลือก B (ที่ใช้อยู่): Claude scheduled routine เขียนบทความใต้ subscription
#   แล้ว POST เข้า /api/ingest → ไม่ต้องใช้ ANTHROPIC_API_KEY (ประหยัดค่า API)
# ทางเลือก A (ถ้าจะให้แอปเรียก AI เอง): ใส่ key จาก https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# โมเดล (ใช้เมื่อเลือกทาง A) — แนะนำ claude-sonnet-5 เพื่อคุมค่าใช้จ่าย
ANTHROPIC_MODEL=claude-sonnet-5

# --- ทางเลือก: Gemini (โครงรองรับสลับ provider) ---------------------------
# ที่มา: https://aistudio.google.com/apikey  (ปล่อยว่างไว้ได้ถ้ายังไม่ใช้)
# ตั้ง TEXT_PROVIDER=gemini เพื่อสลับไปใช้ Gemini แทน Claude
TEXT_PROVIDER=claude
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- สร้างรูป (Pollinations) -----------------------------------------------
# ฟรี ไม่ต้องใช้ key — ไม่ต้องเติมอะไร
POLLINATIONS_BASE=https://image.pollinations.ai/prompt

# --- LINE Messaging API (แจ้งเตือน + อนุมัติ) ------------------------------
# หมายเหตุ: LINE OA ยังไม่ได้สร้าง → ต้องสร้างใหม่ในเฟส 2
# ที่มา: https://developers.line.biz/console/
#   1) สร้าง Provider → สร้าง Channel แบบ "Messaging API" (= LINE OA ใหม่)
#   2) แท็บ Messaging API → "Channel access token (long-lived)" → Issue
#      → เอามาใส่ LINE_CHANNEL_ACCESS_TOKEN
#   3) แท็บ Basic settings → "Channel secret" → LINE_CHANNEL_SECRET
#   4) เชิญบอทเข้ากลุ่ม LINE ของคุณ แล้วดู group id (ดูวิธีใน README)
#      → เอามาใส่ LINE_GROUP_ID
#   5) ตั้ง Webhook URL = https://<โดเมน Vercel ของคุณ>/api/line/webhook แล้วเปิด Use webhook
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET
LINE_GROUP_ID=YOUR_LINE_GROUP_ID

# --- Facebook Graph API (โพสต์เพจ) ----------------------------------------
# เพจเป้าหมาย: "SiamAthlete" (เพจฟิตเนส/เพาะกายที่มีอยู่แล้ว)
# ที่มา: https://developers.facebook.com/
#   1) สร้าง App (ประเภท Business) → เพิ่มผลิตภัณฑ์ "Facebook Login" / ใช้ Graph API Explorer
#   2) ขอ Page Access Token ของเพจ SiamAthlete สิทธิ์: pages_manage_posts, pages_read_engagement
#      (แนะนำแลกเป็น long-lived token — ดูขั้นตอนใน README)
#   3) หา Page ID ของ SiamAthlete จากหน้าเพจ → About → Page ID
FACEBOOK_PAGE_ID=YOUR_FACEBOOK_PAGE_ID
FACEBOOK_PAGE_ACCESS_TOKEN=YOUR_FACEBOOK_PAGE_ACCESS_TOKEN
FACEBOOK_GRAPH_VERSION=v21.0

# --- เว็บไซต์ + ความปลอดภัย cron -------------------------------------------
# โดเมนสาธารณะของเว็บ (ใช้ประกอบลิงก์เวลาโพสต์ FB)
NEXT_PUBLIC_SITE_URL=https://YOUR-SITE.vercel.app
# ความลับสำหรับป้องกัน endpoint cron (GitHub Actions ส่ง header นี้มา)
CRON_SECRET=SET_A_LONG_RANDOM_STRING_HERE

# --- เกณฑ์สต็อก (ค่าเริ่มต้น ปรับได้ในหลังบ้าน) ----------------------------
STOCK_TARGET=10
STOCK_THRESHOLD=3
